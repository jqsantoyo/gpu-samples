{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    { "name": "debug",     "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug"  }  },
    { "name": "release",   "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release"}  }
  ],
  "buildPresets": [
    { "name": "debug",     "configurePreset": "debug"  },
    { "name": "release",   "configurePreset": "release"}
  ]
}














