{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    { "name": "x64-debug",     "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug"} },
    { "name": "x64-release",   "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release"}  },
    { "name": "mac-arm64-debug",   "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug"}   },
    { "name": "mac-arm64-release", "generator": "Ninja", "binaryDir": ".build/${presetName}", "cacheVariables": { "CMAKE_BUILD_TYPE": "Release"}  }
  ],
  "buildPresets": [
    { "name": "x64-debug",     "configurePreset": "x64-debug"},
    { "name": "x64-release",   "configurePreset": "x64-release"},
    { "name": "mac-arm64-debug",   "configurePreset": "mac-arm64-debug" },
    { "name": "mac-arm64-release", "configurePreset": "mac-arm64-release" }
  ]
}














